# Maintainer: foxstudio-201 <noreply@foxstudio.site>
pkgname=pettato-bin
pkgver=1.0.0
pkgrel=1
pkgdesc="A lightweight, offline desktop virtual pet that lives on your desktop"
arch=('x86_64')
url="https://github.com/foxstudio-201/petTato"
license=('MIT')
depends=('gtk3' 'nss' 'alsa-lib')
provides=('pettato')
conflicts=('pettato')
options=('!strip' '!debug')
source=("pettato-${pkgver}.deb::${url}/releases/download/v${pkgver}/pettato_${pkgver}_amd64.deb")
sha256sums=('063149cf1fac246f1c414c35c8ae232bd49010d27afe18accdd909ad033f2107')

package() {
  # The release .deb already lays files out in FHS form (/opt + .desktop + icon),
  # so we just unpack its data archive straight into the package root.
  bsdtar -xf "pettato-${pkgver}.deb" -C "${srcdir}"
  bsdtar -xf "${srcdir}/data.tar.xz" -C "${pkgdir}"

  # Electron's sandbox helper must be setuid root.
  chmod 4755 "${pkgdir}/opt/petTaTo/chrome-sandbox"

  # CLI launcher.
  install -d "${pkgdir}/usr/bin"
  ln -sf /opt/petTaTo/pettato "${pkgdir}/usr/bin/pettato"
}
